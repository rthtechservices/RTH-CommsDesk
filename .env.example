APP_NAME=RTH CommsDesk
ENV=local
DATABASE_URL=sqlite:///./commsdesk.db
LOG_LEVEL=INFO
LOG_FORMAT=plain
APP_BASE_URL=http://127.0.0.1:8000

GMAIL_CLIENT_SECRETS_FILE=./client_secret.json
GMAIL_TOKEN_FILE=./gmail_token.json
GMAIL_ACCOUNT=me
GMAIL_READ_MAX_RESULTS=100
GMAIL_STORE_FULL_BODY=false
GMAIL_WRITE_ENABLED=false
GMAIL_DRAFT_CREATE_ENABLED=false
GMAIL_SEND_ENABLED=false
GMAIL_LABEL_ARCHIVE_ENABLED=false
GMAIL_NOISE_LABEL_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_ACCOUNT=me
MICROSOFT_GRAPH_ENABLED=false
MICROSOFT_GRAPH_AUTH_MODE=delegated
MICROSOFT_GRAPH_SCOPES=User.Read Mail.Read offline_access
MICROSOFT_GRAPH_TOKEN_FILE=./microsoft_graph_token.json
MICROSOFT_GRAPH_OUTLOOK_MAIL_ENABLED=false
MICROSOFT_GRAPH_TEAMS_ENABLED=false
MICROSOFT_GRAPH_OUTLOOK_CALENDAR_READ_ENABLED=false
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
NOTIFICATION_WEBHOOK_SECRET=

AI_PROVIDER=mock
OPENAI_API_KEY=
AI_MODEL=
AI_BASE_URL=https://api.openai.com/v1
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AI_TIMEOUT_SECONDS=20
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.2
CALENDAR_PROVIDER=mock
GOOGLE_CALENDAR_TOKEN_FILE=./google_calendar_token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIME_ZONE=America/Vancouver
GOOGLE_CALENDAR_READ_ENABLED=false
GOOGLE_CALENDAR_WRITE_ENABLED=false
OUTLOOK_CALENDAR_READ_ENABLED=false
EXECUTION_PROVIDER=mock
EXTERNAL_WRITE_DRY_RUN=true
OPERATIONAL_TEST_MODE=false
EXECUTION_TEST_EMAIL_ALLOWLIST=

APP_AUTH_ENABLED=false
APP_AUTH_USERNAME=
APP_AUTH_PASSWORD=
API_AUTH_TOKEN=
AUTH_SESSION_COOKIE_NAME=commsdesk_session
AUTH_SESSION_SECRET=local-dev-change-me
AUTH_SESSION_TTL_HOURS=12

RETENTION_MESSAGE_BODY_DAYS=90
RETENTION_SENT_LEARNING_DAYS=180
RETENTION_EXECUTION_AUDIT_DAYS=365
